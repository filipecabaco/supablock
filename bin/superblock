#!/bin/sh
# Thin launcher for the superblock Mix release. Resolve the release root
# relative to this script so the tool is relocatable.
SELF="$(cd "$(dirname "$0")" && pwd)"
RELEASE_ROOT="${SUPERBLOCK_RELEASE_ROOT:-$SELF/../_build/prod/rel/superblock}"

# The BEAM wants a UTF-8 locale; fall back to C.UTF-8 when the environment
# doesn't provide one.
case "${LC_ALL:-${LANG:-}}" in
    *[Uu][Tt][Ff]*) : ;;
    *) LC_ALL=C.UTF-8 LANG=C.UTF-8; export LC_ALL LANG ;;
esac

if [ ! -x "$RELEASE_ROOT/bin/superblock" ]; then
    echo "superblock release not found at $RELEASE_ROOT" >&2
    echo "build it with: MIX_ENV=prod mix release" >&2
    exit 4
fi

# `release eval` does not forward argv, so pass the args through an
# environment variable, joined with the unit separator (0x1f) to survive
# spaces. Superblock.CLI.main/0 splits it back out.
SUPERBLOCK_ARGV="$(printf '%s\037' "$@")"
export SUPERBLOCK_ARGV

# Absolute path of this launcher, used by `superblock service install` as
# the program the systemd/launchd service should run.
SUPERBLOCK_BIN="$SELF/$(basename "$0")"
export SUPERBLOCK_BIN

exec "$RELEASE_ROOT/bin/superblock" eval "Superblock.CLI.main()"
